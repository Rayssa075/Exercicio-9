#include <iostream>
#include <string>
using namespace std;

struct Aluno {
    string nome;
    int matricula;
    float media;
};

int main(){
    Aluno alunos[10];
    Aluno aprovados[10];
    Aluno reprovados[10];

 
    int apro= 0;
    int repro= 0;

    for (int i = 0; i<10; i++) {

        cout<<"Aluno " << i + 1 << endl;
        cout<<"Nome: ";
        cin>>alunos[i].nome;
        cout << "Matricula: ";
        cin >> alunos[i].matricula;
        cout << "Media Final: ";
        cin >> alunos[i].media;
        
        if (alunos[i].media>= 5.0) {
            aprovados[apro] = alunos[i];
            apro++;

        } else {

            reprovados[repro] = alunos[i];
            repro++;
        }
    }

    cout << "ALUNOS APROVADOS"<<endl;
    for (int i = 0; i < apro; i++) {

        cout<<"Nome: "<<aprovados[i].nome<<endl;
        cout<<"Matricula: "<<aprovados[i].matricula<<endl;
        cout<<"Media Final: "<<aprovados[i].media<<endl;
    }

    cout <<"ALUNOS REPROVADOS"<<endl;

    for (int i = 0; i < repro; i++) {

        cout<<"Nome: "<<reprovados[i].nome<<endl;
        cout<<"Matricula: "<<reprovados[i].matricula<<endl;
        cout<<"Media Final: "<<reprovados[i].media<<endl;
    }

    return 0;
}
