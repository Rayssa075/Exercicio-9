#include <iostream>
using namespace std;

struct aluno {
    string nome;
    int matricula;
    string curso;
};

int main() {

    aluno a[5];
    for (int i = 0; i < 5; i++) {

        cout << "aluno " << i + 1 << endl;

        cout << "digite o nome ";
        getline(cin, a[i].nome);

        cout << "digite o numero de matricula ";
        cin >> a[i].matricula;
        cin.ignore();

        cout << "digite o curso ";
        getline(cin, a[i].curso);
    }

    for (int i = 0; i < 5; i++) {

        cout << "aluno " << i + 1 << endl;
        cout << "nome: " << a[i].nome << endl;
        cout << "matricula: " << a[i].matricula << endl;
        cout << "curso: " << a[i].curso << endl;
    }

    return 0;
}
